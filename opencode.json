{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "openai/gpt-5.3-codex",
  "default_agent": "architect",
  "provider": {
    "openai": {
      "options": {
        "websearch_cited": {
          "model": "gpt-5.4"
        }
      }
    },
    "anthropic": {
      "options": {
        "websearch_cited": {
          "model": "claude-sonnet-4-6"
        }
      }
    }
  },
  "agent": {
    "architect": {
      "tools": {
        "sequential-thinking_*": true,
        "superlocalmemory_*": true
      }
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "environment": {
        "CONTEXT7_API_KEY": "{file:~/.config/opencode/.secrets/context7_api_key}"
      }
    },
    "sequential-thinking": {
      "enabled": true,
      "type": "local",
      "command":[
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "superlocalmemory": {
      "enabled": true,
      "type": "local",
      "command": ["slm", "mcp"]
    },
    "playwright": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--headless"
      ]
    },
    "next-devtools": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "mcp_server_mysql_core": {
      "enabled": false,
      "type": "local",
      "command": [
        "/Users/joshuamcnabb/.nvm/versions/node/v20.10.0/bin/npx",
        "-y",
        "@benborla29/mcp-server-mysql"
      ],
      "environment": {
        "MYSQL_HOST": "{file:~/.config/opencode/.secrets/mysql_host}",
        "MYSQL_PORT": "{file:~/.config/opencode/.secrets/mysql_port}",
        "MYSQL_USER": "{file:~/.config/opencode/.secrets/mysql_user}",
        "MYSQL_PASS": "{file:~/.config/opencode/.secrets/mysql_pass}",
        "MYSQL_DB": "{file:~/.config/opencode/.secrets/mysql_db}",
        "PATH": "/Users/joshuamcnabb/.nvm/versions/node/v20.10.0/bin:/usr/bin:/bin",
        "ALLOW_INSERT_OPERATION": "false",
        "ALLOW_UPDATE_OPERATION": "false",
        "ALLOW_DELETE_OPERATION": "false"
      }
    }
  },
  "instructions": [
    "rules/coding-style.md"
  ],
  "plugin": [
    "@nick-vi/opencode-type-inject",
    "opencode-websearch-cited",
    "@franlol/opencode-md-table-formatter",
    "@mohak34/opencode-notifier",
    "@slkiser/opencode-quota",
    "opencode-vibeguard"
  ]
}
